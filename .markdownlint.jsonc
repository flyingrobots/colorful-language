{
  // Relaxed but meaningful: prose docs, not a style straitjacket.
  "default": true,
  "MD013": false, // line length — prose wraps naturally
  "MD033": false, // inline HTML — allowed for occasional structure
  "MD041": false, // first line need not be a top-level heading
  "MD024": { "siblings_only": true }, // duplicate headings ok across sections
  "MD029": { "style": "ordered" }
}
